# Скопируйте в .env.local и подставьте значения из Supabase → Project Settings → API.
# Облачный проект: URL вида https://<project-ref>.supabase.co (не используйте 127.0.0.1:54321 для деплоя и Docker).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Только локально. На Vercel НЕ добавляйте (в production игнорируется).
# SKIP_AUTH_MIDDLEWARE=true

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Brevo — email-уведомления клиентам при смене статуса (только server-side, не NEXT_PUBLIC_)
# API key: Brevo → SMTP & API → API Keys
# Sender: подтверждённый email в Brevo → Senders
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Emigrant Croatia Desk
# Локально на Windows при ошибке SSL к Brevo: BREVO_SKIP_TLS_VERIFY=true
# (в production не задавать; npm run dev уже задаёт NODE_TLS_REJECT_UNAUTHORIZED=0)
